{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ProfileSpec",
  "description": "JSON schema for hi-agent profile files loaded by load_profiles_from_dir().",
  "type": "object",
  "required": ["profile_id", "display_name"],
  "additionalProperties": true,
  "properties": {
    "profile_id": {
      "type": "string",
      "minLength": 1,
      "description": "Unique identifier for this profile."
    },
    "display_name": {
      "type": "string",
      "minLength": 1,
      "description": "Human-readable name for this profile."
    },
    "description": {
      "type": "string",
      "description": "Optional human-readable description."
    },
    "required_capabilities": {
      "type": "array",
      "items": {"type": "string"},
      "description": "Capability names required by this profile."
    },
    "stage_actions": {
      "type": "object",
      "additionalProperties": {"type": "string"},
      "description": "Maps stage IDs to action_kind strings."
    },
    "config_overrides": {
      "type": "object",
      "description": "Arbitrary config overrides for the platform."
    },
    "metadata": {
      "type": "object",
      "description": "Arbitrary metadata for the profile."
    }
  }
}
