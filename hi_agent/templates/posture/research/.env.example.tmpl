# hi-agent research posture environment variables
# Copy relevant lines to your shell or .env file.

# LLM credentials (required for research posture)
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...

# Posture (dev | research | prod)
HI_AGENT_POSTURE=research

# Config directory (set to your scaffolded config dir)
# HI_AGENT_CONFIG_DIR=./hi_agent_config

# Data directory (required for research posture — durable queue/ledger)
# HI_AGENT_DATA_DIR=/var/hi_agent

# Optional: LLM mode (real | heuristic)
# HI_AGENT_LLM_MODE=real

# Optional: run manager capacity
# HI_AGENT_RUN_MANAGER_CAPACITY=4
