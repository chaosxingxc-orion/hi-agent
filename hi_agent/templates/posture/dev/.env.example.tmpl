# hi-agent dev posture environment variables
# Copy relevant lines to your shell or .env file.

# LLM credentials (at least one required for real LLM mode)
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...

# Posture (dev | research | prod)
HI_AGENT_POSTURE=dev

# Config directory (set to your scaffolded config dir)
# HI_AGENT_CONFIG_DIR=./hi_agent_config

# Optional: data directory for durable storage
# HI_AGENT_DATA_DIR=./.hi_agent_data

# Optional: LLM mode (real | heuristic)
# HI_AGENT_LLM_MODE=real
