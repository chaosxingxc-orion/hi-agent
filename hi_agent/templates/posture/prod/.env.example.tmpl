# hi-agent prod posture environment variables
# Copy relevant lines to your shell or .env file.

# LLM credentials (required for prod posture)
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...

# Posture (dev | research | prod)
HI_AGENT_POSTURE=prod

# Config directory (set to your scaffolded config dir)
# HI_AGENT_CONFIG_DIR=./hi_agent_config

# Data directory (required for prod posture — durable queue/ledger)
# HI_AGENT_DATA_DIR=/var/hi_agent

# LLM mode (required: real for prod)
HI_AGENT_LLM_MODE=real

# Kernel base URL (required for prod)
# HI_AGENT_KERNEL_BASE_URL=http://kernel-host:8090

# Run manager capacity
# HI_AGENT_RUN_MANAGER_CAPACITY=8

# API authentication key
# HI_AGENT_API_KEY=<your-api-key>
