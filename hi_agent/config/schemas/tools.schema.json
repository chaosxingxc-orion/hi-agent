{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "hi-agent tools config",
  "type": "object",
  "required": ["tools"],
  "properties": {
    "version": {"type": "string"},
    "tools": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "handler"],
        "properties": {
          "name": {"type": "string", "minLength": 1},
          "description": {"type": "string"},
          "timeout_s": {"type": "number", "minimum": 0},
          "tags": {"type": "array", "items": {"type": "string"}},
          "input_schema": {"type": "object"},
          "handler": {
            "type": "object",
            "required": ["type"],
            "properties": {
              "type": {"type": "string", "enum": ["http", "shell", "python"]},
              "url": {"type": "string"},
              "method": {"type": "string"},
              "command": {"type": "string"},
              "allowed_args": {"type": "array", "items": {"type": "string"}},
              "callable": {"type": "string"}
            }
          }
        }
      }
    }
  }
}
